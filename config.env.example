# ===========================================
# Telegram Restriction Bypass - Configuration
# ===========================================
#
# This file contains all configuration options for the bot.
# Copy this file to config.env and fill in your credentials.
#
# SECURITY WARNING:
# - Never commit config.env to Git
# - Never share your credentials with anyone
# - Keep this file secure and private
#

# ===========================================
# Telegram API Credentials (REQUIRED)
# ===========================================
# Get these from https://my.telegram.org
# 1. Log in with your phone number
# 2. Go to "API Development Tools"
# 3. Create a new application
# 4. Copy api_id and api_hash

API_ID=YOUR_API_ID_HERE
API_HASH=YOUR_API_HASH_HERE

# ===========================================
# Bot Token (REQUIRED)
# ===========================================
# Get from @BotFather on Telegram:
# 1. Send /newbot to @BotFather
# 2. Follow instructions to create bot
# 3. Copy the token provided
#
# MULTIPLE BOTS (Optional):
# Add multiple tokens separated by commas for worker pool
# Example: BOT_TOKENS=token1,token2,token3

BOT_TOKENS=YOUR_BOT_TOKEN_HERE

# ===========================================
# User Session String (OPTIONAL)
# ===========================================
# Required ONLY for USER mode (accessing restricted/private channels)
# If not provided, bot will run in BOT mode only (public channels)
#
# Generate using:
# 1. Run: python
# 2. Execute:
#    from pyrogram import Client
#    api_id = YOUR_API_ID
#    api_hash = "YOUR_API_HASH"
#    with Client("my_account", api_id, api_hash) as app:
#        print(app.export_session_string())
#
# SECURITY: This grants full access to your Telegram account!
# - Never share this with anyone
# - Never commit to Git
# - Revoke immediately if compromised

SESSION_STRING=YOUR_SESSION_STRING_HERE

# ===========================================
# Performance Tuning (OPTIONAL)
# ===========================================
# Adjust these based on your system resources and network speed

# Maximum concurrent downloads (default: 3)
# Higher = faster but more RAM/CPU usage
# Recommended: 3-5 for VPS, 2-3 for low-end systems
MAX_CONCURRENT_DOWNLOADS=3

# Delay between batches in seconds (default: 3)
# Higher = slower but less chance of FloodWait
# Recommended: 2-5 depending on download frequency
FLOOD_WAIT_DELAY=3

# Number of messages to fetch per batch (default: 10)
# Higher = fewer API calls but more memory usage
# Recommended: 10-200
BATCH_SIZE=10

# ===========================================
# Advanced Options (OPTIONAL)
# ===========================================
# Usually not needed, only change if you know what you're doing

# Timezone (default: UTC)
# TZ=America/New_York

# Log level (default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# ===========================================
# Notes
# ===========================================
#
# REQUIRED vs OPTIONAL:
# - API_ID: REQUIRED
# - API_HASH: REQUIRED
# - BOT_TOKENS: REQUIRED (at least one token)
# - SESSION_STRING: OPTIONAL (needed for USER mode only)
# - Performance settings: OPTIONAL (have sensible defaults)
#
# COMMON ISSUES:
# 1. "API_HASH is not configured" - Replace YOUR_API_HASH_HERE
# 2. "BOT_TOKENS must be set" - Replace YOUR_BOT_TOKEN_HERE
# 3. Bot doesn't access restricted content - Add SESSION_STRING
#
# GETTING HELP:
# - Read docs/INSTALLATION.md for detailed setup
# - Read docs/SETUP.md for configuration guide
# - Check docs/README.md for troubleshooting
# - Open issue: https://github.com/Paidguy/TelegramRestrictionBypass/issues
#
